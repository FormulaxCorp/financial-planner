{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "node_modules",
      "**/*.sh",
      "**/*.py",
      "**/*.bat",
      "**/*.exe",
      "**/*.cmd",
      "**/*.ps1",
      "README.md",
      "readme.txt",
      "preview/**",
      "service-account.json",
      ".git",
      ".gitignore"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
